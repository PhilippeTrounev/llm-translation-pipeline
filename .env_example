# Copy this file to .env and fill only the values you need.
# Keep .env private; it is ignored by git in this workspace.

# Main translation settings
TRANSLATION_PROVIDER=bedrock
SOURCE_LANGUAGE=German
TARGET_LANGUAGE=Russian
SOURCE_LANGUAGE_CODE=de
TARGET_LANGUAGE_CODE=ru
TRANSLATION_STYLE="Stay close to the source syntax and terminology without becoming unreadable."
TRANSLATION_GLOSSARY_FILE=
TRANSLATION_OUTPUT_DIR=md_ru
TRANSLATION_CHUNKS_DIR=translation_chunks
TRANSLATION_MAX_CHARS=18000
TRANSLATION_MAX_TOKENS=9000
TRANSLATION_TEMPERATURE=0.1
TRANSLATION_RETRIES=4
TRANSLATION_TIMEOUT_SECONDS=900
TRANSLATION_WORKERS=1

# AWS Bedrock provider
AWS_PROFILE=
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=qwen.qwen3-32b-v1:0

# Ollama provider
# Local Ollama:
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
# Direct Ollama Cloud API, no local pull needed:
# OLLAMA_HOST=https://ollama.com
# OLLAMA_MODEL=gpt-oss:120b
OLLAMA_API_KEY=

# Mistral OCR provider. Use only when PDF text extraction is bad or scanned.
MISTRAL_API_KEY=replace_with_your_mistral_key
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_OUTPUT_DIR=mistral_ocr_md
MISTRAL_OCR_RAW_DIR=mistral_ocr_md/raw
MISTRAL_OCR_CHUNK_PAGES=100
MISTRAL_OCR_TIMEOUT_MS=600000

# DOCX export
DOCX_OUTPUT_DIR=docx_ru
PANDOC_REFERENCE_DOC=
